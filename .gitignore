# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments (includes .venv/.tuffy_cuda_ready, the Jetson CUDA-build marker)
.venv

# Test cache
.pytest_cache/

# Model weights (large files)
src/models/weights/

# User memory / personal data
data/

# Agent workspace (temporary execution artifacts)
agent_workspace/

# OS-specific files
.DS_Store

# IDE / Project local configurations
.vscode/
.idea/
.gemini/
.agents/
.claude/

# Editor / Extension packages
*.vsix

# Local MCP server config (may contain commands/env referencing local paths or secrets)
.tuffy/mcp.json

# Local user settings (e.g. chosen default model), machine-specific
.tuffy/settings.json

# API keys / secrets, read directly by src/llm/openai_compatible_provider.py
.env

